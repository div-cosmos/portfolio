# Copy this to .env.local for local dev, and add the same keys in Vercel
# (Project → Settings → Environment Variables) before you deploy.

# --- Supabase: where the messages get saved ---
# Your project URL, looks like https://xxxxxxxx.supabase.co
SUPABASE_URL=
# The service-role key. This one's powerful, so keep it on the server only.
# Never ship it to the browser and never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend: the email that lands in your inbox ---
RESEND_API_KEY=
# Who the email comes from. onboarding@resend.dev works out of the box for
# testing; swap in your own domain once you've verified it.
RESEND_FROM=Portfolio <onboarding@resend.dev>
# Where you actually want to read these messages.
CONTACT_TO_EMAIL=divyanshuverma919@gmail.com

# --- CallMeBot: the WhatsApp ping to your phone ---
# Your number, with the country code, e.g. +917300099947
CALLMEBOT_PHONE=
# The key CallMeBot texts back to you after you send the one-time activation message.
CALLMEBOT_APIKEY=

# --- Frontend (you can usually ignore this) ---
# Only needed if the API and the site live on different domains. Otherwise it
# just defaults to /api/contact on the same origin.
# VITE_CONTACT_ENDPOINT=https://your-app.vercel.app/api/contact
